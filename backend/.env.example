# The Odds API - Primary odds source
# Sign up at https://the-odds-api.com to get your API key
# Paid tier (20k requests/month) recommended for production use.
# Then copy this file to .env and fill in your key:
#   cp .env.example .env
ODDS_API_KEY=your_api_key_here

# BallDontLie API - NBA data source
# Sign up at https://www.balldontlie.io to get your API key.
# Required for NBA team/schedule/stats syncing.
BALLDONTLIE_API_KEY=your_api_key_here
